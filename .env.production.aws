services:
  phpmyadmin:
    image: phpmyadmin
    container_name: phpmyadmin
    restart: always
    ports:
      - 8090:80
    environment:
      PMA_HOST: database-projet.c3agsaymkxi0.eu-west-3.rds.amazonaws.com
      PMA_USER: nestjs_user
      PMA_PASSWORD: root_password
    networks:
      - gestion_fichier-network-dev
  backend:
    build: .
    container_name: nestjs_api
    expose:
      - "3000"
    env_file:
      - ./.env.production
