// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum EnumUserStatus {
  NOT_CONFIRMED
  CONFIRMED
  DEACTIVATED
  BANNED
}

model User {
  id                      Int                   @id @default(autoincrement()) 
  username                String                @db.VarChar(50)
  email                   String                @unique() @db.VarChar(50)
  password                String                @db.VarChar(100)
  extraEmail              String?               @unique() @db.VarChar(50)
  status                  EnumUserStatus
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  files                   File[]  
  fileRequests            FileRequest[]
  memberGroups            MemberGroup[]
  messages                Message[]  
  shares_with_users       ShareWithUsers[]
  accessLogs              AccessLog[]
  changeLogs              ChangeLog[]
  groups                  Group[]
  tokens                  Token[]
}

enum EnumStatusFile {
  HOME
  BIN 
  DELETED 
  ARCHIVED
}

model File {
  id              Int              @id @default(autoincrement()) 
  name            String           @db.VarChar(255) @unique
  size            Int?             
  user            User             @relation(fields: [userId], references: [id])
  userId          Int             
  path            String           @db.VarChar(255)
  mimeType        String           @db.VarChar(255)
  status          EnumStatusFile? 
  shareUrl        String?          @db.VarChar(255)  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  parent          File?            @relation(name: "parent", fields: [parentId], references: [id])  
  parentId        Int?             @unique
  version         String?          @db.VarChar(255)
  fileRequests    FileRequest[]
  accessLogs      AccessLog[]
  changeLogs      ChangeLog[]
  childs          File[]           @relation(name: "parent")
  sharesUsers ShareWithUsers[]
  sharesGroups ShareWithGroups[]
}

model Group {
  id                      Int                   @id @default(autoincrement()) 
  leaderId                Int
  leader                  User                  @relation(fields: [leaderId], references: [id])
  name                    String                @db.VarChar(50)
  memberGroups            MemberGroup[]
  fileRequests            FileRequest[]
  messages                Message[]
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  shareGroups             ShareWithGroups[]
}

model MemberGroup {
  user      User      @relation(fields: [userId], references: [id])
  userId    Int
  group     Group     @relation(fields: [groupId], references: [id])
  groupId   Int
  @@id([userId, groupId])
}

model FileRequest {
  senderId      Int
  sender        User            @relation(fields: [senderId], references: [id])
  fileId        Int
  file          File            @relation(fields: [fileId], references: [id])
  groupId       Int
  group         Group           @relation(fields: [groupId], references: [id])
  typeRequest   EnumTypeRequest
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  @@id([senderId, fileId, groupId])
}

enum EnumTypeRequest {
  SHAREFILE
  JOINGROUP
  ACCESSFILE
  DELETEFILE
}

model Message {
  id            Int             @id @default(autoincrement()) 
  message       String          @db.Text()
  sender        User            @relation(fields: [senderId], references: [id])
  senderId      Int
  groupId       Int
  group         Group           @relation(fields: [groupId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}
model ShareWithUsers {
  fileId             Int      
  file               File              @relation(fields: [fileId], references: [id])
  userId             Int
  user               User              @relation(fields: [userId], references: [id])
  accessType         EnumAccessType
  expirationDate     DateTime?
  status             EnumStatusShare?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  @@id([fileId, userId])
}


model ShareWithGroups {
  fileId             Int      
  file               File            @relation(fields: [fileId], references: [id])
  groupId            Int
  group              Group           @relation(fields: [groupId], references: [id])
  accessType         EnumAccessType
  expirationDate     DateTime?
  status             EnumStatusShare?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  @@id([fileId, groupId])
}

enum EnumAccessType {
  READ
  WRITE
}

enum EnumStatusShare {
  EDITED
  DELETED
  ARCHIVED
}

model AccessLog {
  fileId          Int
  file            File                  @relation(fields: [fileId], references: [id])
  userId          Int
  user            User                  @relation(fields: [userId], references: [id])
  startDate       DateTime              @default(now())
  endDate         DateTime              @default(now())
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  @@id([fileId, userId])
}

model ChangeLog {
  fileId                Int
  file                  File                  @relation(fields: [fileId], references: [id])
  userId                Int
  user                  User                  @relation(fields: [userId], references: [id])
  numeroVersion         Int
  content               String                @db.Text()
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  actionType            EnumActionType
  @@id([fileId, userId])
}

enum EnumActionType {
  RENAME
  EDIT
}

enum EnumTokenType {
  REFRESHTOKEN
  ACTIVATEACCOUNT
  RESETPASSWORD
  SHARE_TOKEN
}

model Token {
  token       String
  type        EnumTokenType
  userId      Int
  user        User              @relation(fields: [userId], references: [id])
  expiresAt   DateTime? 
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  @@id([token, userId])
}