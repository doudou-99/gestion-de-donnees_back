// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum EnumUserStatus {
  NOT_CONFIRMED
  CONFIRMED
  DEACTIVATED
  BANNED
}

model User {
  id                      Int                   @id @default(autoincrement()) 
  username                String                @db.VarChar(50)
  email                   String                @unique() @db.VarChar(50)
  password                String                @db.VarChar(100)
  address                 String                @db.VarChar(100)
  additionalAddress       String?               @db.VarChar(100)
  zipCode                 String
  extraEmail              String?               @unique() @db.VarChar(50)
  status                  EnumUserStatus
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  files                   File[]  
  fileRequests            FileRequest[]
  memberGroups            MemberGroup[]
  messages                Message[]  
  shares                  Share[]
  shares_with_users       ShareWithUsers[]
  shares_with_groups      ShareWithGroups[]
  accessLogs              AccessLog[]
  changeLogs              ChangeLog[]
  groups                  Group[]
  tokens                  Token[]
}

model Type {
  id              Int              @id @default(autoincrement()) 
  typeName        String           @db.VarChar(50)
  typeDescription String           @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt  
  files           File[]
}

model File {
  id              Int              @id @default(autoincrement()) 
  name            String           @db.VarChar(255) @unique
  size            Int?             
  user            User             @relation(fields: [userId], references: [id])
  userId          Int             
  typeId          Int
  url             String           @db.VarChar(255)
  type            Type             @relation(fields: [typeId], references: [id])
  editFile        EnumEditFile?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  version         String?          @db.VarChar(255)
  filePermission  String?          @db.VarChar(255)
  fileRequests    FileRequest[]
  messages        Contains[]
  shares          Share[]
  accessLogs      AccessLog[]
  changeLogs      ChangeLog[]
}

enum EnumEditFile {
  DATEFILE
  USEREDIT
}

model Group {
  id                      Int                   @id @default(autoincrement()) 
  leaderId                Int
  leader                  User                  @relation(fields: [leaderId], references: [id])
  name                    String                @db.VarChar(50)
  memberGroups            MemberGroup[]
  fileRequests            FileRequest[]
  messages                Message[]
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
}

model MemberGroup {
  user      User      @relation(fields: [userId], references: [id])
  userId    Int
  group     Group     @relation(fields: [groupId], references: [id])
  groupId   Int
  @@id([userId, groupId])
}

model FileRequest {
  id            Int             @id @default(autoincrement()) 
  typeRequest   EnumTypeRequest
  senderId      Int
  sender        User            @relation(fields: [senderId], references: [id])
  fileId        Int
  file          File            @relation(fields: [fileId], references: [id])
  groupId       Int
  group         Group           @relation(fields: [groupId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum EnumTypeRequest {
  SHAREFILE
  JOINGROUP
  ACCESSFILE
  DELETEFILE
}

model Message {
  id            Int             @id @default(autoincrement()) 
  message       String          @db.Text()
  sender        User            @relation(fields: [senderId], references: [id])
  senderId      Int
  groupId       Int
  group         Group           @relation(fields: [groupId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  files         Contains[]
}

model Contains {
  idMessage    Int           
  message      Message         @relation(fields: [idMessage], references: [id])
  idFile       Int      
  file         File            @relation(fields: [idFile], references: [id])
  @@id([idMessage, idFile])
}

model Share {
  id                    Int                   @id @default(autoincrement()) 
  shareUrl              String                @db.VarChar(255)
  userId                Int             
  user                  User                  @relation(fields: [userId], references: [id])
  file                  File                  @relation(fields: [fileId], references: [id])
  fileId                Int            
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  sharesWithUsers       ShareWithUsers[]
  sharesWithGroups      ShareWithGroups[]
}
  

model ShareWithUsers {
  shareId            Int             
  share              Share             @relation(fields: [shareId], references: [id])    
  userId             Int
  user               User              @relation(fields: [userId], references: [id])
  accessType         EnumAccessType
  expirationDate     DateTime?
  status             EnumStatusShare?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  @@id([shareId, userId])
}


model ShareWithGroups {
  shareId            Int            
  share              Share           @relation(fields: [shareId], references: [id])    
  userId             Int
  user               User            @relation(fields: [userId], references: [id])
  accessType         EnumAccessType
  expirationDate     DateTime?
  status             EnumStatusShare?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  @@id([shareId, userId])
}

enum EnumAccessType {
  READ
  WRITE
}

enum EnumStatusShare {
  EDITED
  DELETED
  ARCHIVED
}

model AccessLog {
  id              Int                   @id @default(autoincrement()) 
  startDate       DateTime              @default(now())
  endDate         DateTime              @default(now())
  fileId          Int
  file            File                  @relation(fields: [fileId], references: [id])
  userId          Int
  user            User                  @relation(fields: [userId], references: [id])
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model ChangeLog {
  id                    Int                   @id @default(autoincrement())
  numeroVersion         Int
  content               String                @db.Text()
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  fileId                Int
  file                  File                  @relation(fields: [fileId], references: [id])
  userId                Int
  user                  User                  @relation(fields: [userId], references: [id])
  actionType            EnumActionType
}

enum EnumActionType {
  RENAME
  EDIT
}

enum EnumTokenType {
  REFRESHTOKEN
  ACTIVATEACCOUNT
  RESETPASSWORD
}

model Token {
  token       String
  type        EnumTokenType
  userId      Int
  user        User              @relation(fields: [userId], references: [id])
  expiresAt   DateTime? 
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  @@id([type, userId])
}